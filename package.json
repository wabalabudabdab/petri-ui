{
  "name": "@wabalabudabdab/petri-ui",
  "version": "0.3.0",
  "description": "UI компоненты Petri — React + Radix UI + Tailwind CSS + CVA",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./components/*": { "import": "./dist/components/*.js", "types": "./dist/components/*.d.ts" },
    "./hooks/*": { "import": "./dist/hooks/*.js", "types": "./dist/hooks/*.d.ts" },
    "./lib/*": { "import": "./dist/lib/*.js", "types": "./dist/lib/*.d.ts" }
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "registry": "https://npm.pkg.github.com" },
  "scripts": {
    "build": "tsup",
    "build:docs": "cd docs && bun run build",
    "dev": "tsup --watch",
    "dev:docs": "cd docs && bun run dev",
    "clean": "rm -rf dist docs/out docs/.next"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.532.0",
    "react-day-picker": "^9.10.0",
    "react-hook-form": "^7.54.0",
    "sonner": "^2.0.6",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.4.0",
    "typescript": "^5"
  },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/wabalabudabdab/petri-ui.git" },
  "homepage": "https://wabalabudabdab.github.io/petri-ui"
}
